##############################################################################
# Dot.Agents — Production Environment Template
#
# REQUIRED PRODUCTION SETTINGS (enforce all before going live):
#   APP_DEBUG=false          — never expose stack traces in production
#   QUEUE_CONNECTION=redis   — database queue is not reliable under load
#   SESSION_DRIVER=redis     — database sessions cause contention at scale
#   HORIZON_ADMIN_EMAILS     — must name at least one real admin email
#   All CHANGE_ME_IN_PRODUCTION values must be replaced with real secrets
##############################################################################

APP_NAME="Dot.Agents"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.dotagents.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=dotagents
DB_USERNAME=dotagents
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

# Horizon dashboard access: comma-separated admin email addresses
HORIZON_ADMIN_EMAILS=admin@yourdomain.com

CACHE_STORE=redis
CACHE_PREFIX=dotagents_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=agents.infodot.co.za
MAIL_PORT=465
MAIL_USERNAME=live@agents.infodot.co.za
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="live@agents.infodot.co.za"
MAIL_FROM_NAME="${APP_NAME}"

# ── Storage (S3 or compatible) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=dotagents-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_ORGANIZATION=
ANTHROPIC_API_KEY=CHANGE_ME

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_KEY=pk_live_CHANGE_ME
STRIPE_SECRET=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Horizon ───────────────────────────────────────────────────────────────────
HORIZON_NAME="Dot.Agents"
HORIZON_DOMAIN=

# ── Backup (Spatie Laravel Backup) ────────────────────────────────────────────
BACKUP_NOTIFICATION_EMAIL=engineering@dotagents.com
BACKUP_DISK=s3
BACKUP_S3_BUCKET=dotagents-backups

VITE_APP_NAME="${APP_NAME}"
